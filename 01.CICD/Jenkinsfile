pipeline {
    agent any
    tools {
        maven 'maven-3.8.4'
        gradle 'gradle-8.14.2'
    }
    parameters {
        choice(name: 'build_tool',
               choices: ['maven', 'gradle'],
               description: 'Choose the build tool for this deployment'
        )
    }

    stages {
        stage('Build with Maven') {
            when {
                expression { params.build_tool == 'maven' }
            }
            steps {
            dir('01.CICD'){
                sh 'mvn clean package'
            }
            }
        }
        stage('Build with Gradle') {
            when {
                expression { params.build_tool == 'gradle' }
            }
            steps {
            dir('01.CICD'){
                sh 'chmod +x gradlew'
                sh './gradlew build'
            }
            }
        }
         stage('Manual Promotion - QA') {
                    steps {
                        script {
                            input message: 'Promote to QA?', ok: 'Promote',
                                  submitterParameter: 'APPROVER'
                            echo "Promoted to QA by: ${env.APPROVER}"
                        }
                    }
                }
                stage('Manual Promotion - PROD') {
                    steps {
                        script {
                            input message: 'Deploy to Production?', ok: 'Deploy',
                                  submitter: 'admin',
                                  submitterParameter: 'DEPLOYER'
                            echo "Deploying to Production..."
                            echo "Deployed by: ${env.DEPLOYER}"
                        }
                    }
                }
     }
}